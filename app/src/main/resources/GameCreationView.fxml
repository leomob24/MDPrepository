<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125579.view.GameCreationView">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Create your SuperHero">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>

    <GridPane hgap="10.0" vgap="10.0">
        <Label text="name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtName" promptText="Enter hero name" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="superpower:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <ComboBox fx:id="comboSuperpower" prefWidth="150.0" promptText="Choose one..." GridPane.columnIndex="1" GridPane.rowIndex="1" />
    </GridPane>

    <Button fx:id="btnCreate" mnemonicParsing="false" onAction="#handleCreateHero" text="Create" />
</VBox>