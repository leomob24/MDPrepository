<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg125579.view.MainView">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <VBox prefWidth="250.0" spacing="10.0" style="-fx-border-color: gray; -fx-border-width: 1; -fx-padding: 10;">
        <Label text="Combatti:">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>
        <Label fx:id="lblHeroName" text="Hero Name: ---" />
        <Label fx:id="lblAtk" text="ATK: ---" />
        <Label fx:id="lblDef" text="DEF: ---" />
        <Label fx:id="lblHp" text="HP: ---" />
        <Label fx:id="lblBonusAtk" text="Bonus ATK: ---" />
        <Label fx:id="lblSuperpowerName" text="Superpower: ---" />
        <Label fx:id="lblSuperpowerDesc" text="Description: ---" wrapText="true" />
        <Label fx:id="lblLevel" text="Livello: ---" />
        <Label fx:id="lblXp" text="XP: ---" />
        <HBox spacing="10.0">
            <Button fx:id="btnBack" mnemonicParsing="false" onAction="#handleBack" text="Back" />
            <Button fx:id="btnSfida" mnemonicParsing="false" onAction="#handleChallengeEnemy" text="SFIDA" />
        </HBox>
    </VBox>

    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
        <Label text="enemy list">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
        <TableView fx:id="enemyTable" prefHeight="300.0" prefWidth="300.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colEnemyName" prefWidth="100.0" text="Name" />
                <TableColumn fx:id="colEnemyAtk" prefWidth="60.0" text="ATK" />
                <TableColumn fx:id="colEnemyDef" prefWidth="60.0" text="DEF" />
                <TableColumn fx:id="colEnemyHp" prefWidth="60.0" text="HP" />
            </columns>
        </TableView>
    </VBox>
</HBox>